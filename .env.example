# self-improving-system-builder — environment variable reference
# Copy to .env, fill in, then: source .env

# ── Model Providers (model_caller.py priority chain) ─────────────────────
# Priority: ZAI > ANTHROPIC > OPENAI > OLLAMA (local fallback, no key needed)
ZAI_API_KEY=
ZAI_MODEL=glm-4-plus

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Brain Connection ────────────────────────────────────────────────────
# Path to the-brain clone (brain_client.py 5-path resolver uses this)
BRAIN_PATH=../the-brain
BRAIN_MCP_HOST=localhost
BRAIN_MCP_PORT=9001
BRAIN_MCP_TOKEN=   # must match the-brain's BRAIN_MCP_TOKEN

# ── Conductor Shell ───────────────────────────────────────────────────
# Path to conductor-protocol-v2 (for conductor_shell.py routing)
CONDUCTOR_PATH=../conductor-protocol-v2
# Max restarts before conductor_shell gives up and pages for human
CONDUCTOR_MAX_RESTARTS=10
# Seconds between watch cycles
DISPATCHER_INTERVAL=60

# ── build-watch ─────────────────────────────────────────────────────
BUILD_WATCH_DIR=.build-watch

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
